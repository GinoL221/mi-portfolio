---
import Layout from "@/layouts/Layout.astro";
import SectionContainer from "@/components/SectionContainer.astro";
import CaseStudy from "@/components/CaseStudy.astro";
import { PROJECTS } from "@/data/projects";

export async function getStaticPaths() {
  return PROJECTS.filter((p) => p.caseStudy != null).map((p) => ({
    params: { slug: p.caseStudy!.slug },
    props: { project: p },
  }));
}

const { project } = Astro.props;
const { title, image, caseStudy } = project;

const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/projects/*.{jpeg,jpg,png,gif,webp}"
);

const imagePath = `/src/assets/projects/${image}`;
if (!images[imagePath]) {
  throw new Error(
    `"${imagePath}" does not exist in glob: "src/assets/projects/*.{jpeg,jpg,png,gif,webp}"`
  );
}
---

<Layout
  title={`${title} — Case Study | Gino Lencina`}
  description={caseStudy?.tagline}
>
  <SectionContainer class="py-12 md:py-16">
    <a
      href="/#proyectos"
      class="inline-flex items-center gap-2 mb-10 px-6 py-3 text-sm font-medium text-white bg-gray-900 rounded-full hover:bg-gray-700 dark:bg-white dark:text-gray-900 dark:hover:bg-gray-200 transition-colors focus-visible:ring-2 focus-visible:ring-yellow-500 focus-visible:ring-offset-2 focus:outline-none"
    >
      <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
      </svg>
      Volver a proyectos
    </a>

    <CaseStudy project={project} heroImage={images[imagePath]} />
  </SectionContainer>
</Layout>
