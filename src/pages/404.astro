---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Página no encontrada — Gino Lencina" description="La página que buscas no existe.">
  <main class="flex flex-col items-center justify-center min-h-screen px-4 text-center">
    <div class="mb-8">
      <span
        class="text-[10rem] sm:text-[12rem] font-bold leading-none bg-gradient-to-b from-gray-200 to-gray-600 dark:from-gray-600 dark:to-gray-900 bg-clip-text text-transparent select-none"
        aria-hidden="true"
      >
        404
      </span>
    </div>

    <h1 class="text-2xl sm:text-3xl font-semibold text-gray-800 dark:text-gray-100 mb-3">
      Página no encontrada
    </h1>

    <p class="text-gray-600 dark:text-gray-400 max-w-md mb-10">
      La página que estás buscando no existe, se movió o está disponible bajo otra URL.
    </p>

    <a
      href="/"
      class="inline-flex items-center gap-2 px-6 py-3 text-sm font-medium text-white bg-gray-900 rounded-full hover:bg-gray-700 dark:bg-white dark:text-gray-900 dark:hover:bg-gray-200 transition-colors focus-visible:ring-2 focus-visible:ring-yellow-500 focus-visible:ring-offset-2 focus:outline-none"
    >
      <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
      </svg>
      Volver al inicio
    </a>
  </main>
</Layout>
