---
import { CORE_CERTIFICATIONS, AI_CERTIFICATIONS } from "@/data/certifications";
---

<div class="flex flex-col gap-y-8">
  <div>
    <h3 class="mb-3 text-lg font-semibold text-gray-800 dark:text-gray-200">
      Desarrollo e Infraestructura
    </h3>
    <ul
      class="flex flex-wrap gap-2"
    >
      {CORE_CERTIFICATIONS.map(({ name, institution, date }) => (
        <li
          class="flex-1 min-w-[260px] p-4 rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900"
        >
          <p class="font-medium text-gray-800 dark:text-gray-100">{name}</p>
          <p class="text-sm text-gray-500 dark:text-gray-400">{institution}</p>
          {date && (
            <p class="mt-1 text-xs text-gray-400 dark:text-gray-500">
              {date}
            </p>
          )}
        </li>
      ))}
    </ul>
  </div>

  <div>
    <h3 class="mb-3 text-lg font-semibold text-gray-800 dark:text-gray-200">
      Inteligencia Artificial
    </h3>
    <ul
      class="flex flex-wrap gap-2"
    >
      {AI_CERTIFICATIONS.map(({ name, institution }) => (
        <li
          class="flex-1 min-w-[220px] p-4 rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900"
        >
          <p class="font-medium text-gray-800 dark:text-gray-100">{name}</p>
          <p class="text-sm text-gray-500 dark:text-gray-400">{institution}</p>
        </li>
      ))}
    </ul>
  </div>
</div>
