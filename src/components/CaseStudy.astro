---
import { Image } from "astro:assets";
import { render, type CollectionEntry } from "astro:content";
import GitHubIcon from "@/icons/GitHubIcon.astro";
import LinkIcon from "@/icons/LinkIcon.astro";
import { TAGS } from "@/data/projects";

export interface Props {
  project: CollectionEntry<"projects">;
  heroImage: () => Promise<{ default: ImageMetadata }>;
}

const { project, heroImage } = Astro.props;
const { title, github, link, tags, tagline, metrics } = project.data;

const { Content } = await render(project);
---

<article class="flex flex-col gap-y-12">
  <!-- Header -->
  <header class="flex flex-col gap-y-4">
    <div class="flex flex-wrap gap-x-2">
      {
        tags.map((tagKey) => {
          const tag = TAGS[tagKey as keyof typeof TAGS];
          if (!tag) return null;
          return (
            <span class={`flex items-center gap-x-2 rounded-full text-sm border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-700 dark:text-gray-300 py-1 px-3 whitespace-nowrap transition-colors duration-200 cursor-default ${tag.hoverClass}`}>
              <tag.icon class="size-4" />
              {tag.name}
            </span>
          );
        })
      }
    </div>
    <h1 class="text-4xl font-bold text-gray-800 dark:text-gray-100">{title}</h1>
    {
      tagline && (
        <p class="text-xl text-gray-600 dark:text-gray-400 text-pretty">
          {tagline}
        </p>
      )
    }
    <footer class="flex gap-x-4">
      {
        github && (
          <a
            href={github}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 px-3 py-2 text-sm text-gray-800 transition bg-white border border-gray-300 rounded-lg dark:bg-gray-800 dark:border-gray-600 dark:text-white hover:bg-gray-100 dark:hover:bg-gray-700 focus:outline-none focus:ring-4 focus:ring-gray-100 dark:focus:ring-gray-700"
          >
            <GitHubIcon class="size-6" />
            Código
          </a>
        )
      }
      {
        link && link !== github && (
          <a
            href={link}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 px-3 py-2 text-sm text-gray-800 transition bg-white border border-gray-300 rounded-lg dark:bg-gray-800 dark:border-gray-600 dark:text-white hover:bg-gray-100 dark:hover:bg-gray-700 focus:outline-none focus:ring-4 focus:ring-gray-100 dark:focus:ring-gray-700"
          >
            <LinkIcon class="size-4" />
            Sitio Web
          </a>
        )
      }
    </footer>
  </header>

  <!-- Hero image -->
  <div class="overflow-clip rounded-xl shadow-xl lg:border lg:border-gray-200 dark:lg:border-gray-800">
    <Image
      alt={`Captura de pantalla de ${title}`}
      class="object-cover object-top w-full"
      src={heroImage()}
    />
  </div>

  <!-- Metrics strip -->
  {
    metrics && metrics.length > 0 && (
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        {metrics.map(({ label, value }) => (
          <div class="flex flex-col items-center gap-y-1 rounded-xl border border-gray-200 dark:border-gray-700 p-4 text-center">
            <span class="text-3xl font-bold text-accent">
              {value}
            </span>
            <span class="text-xs text-gray-500 dark:text-gray-400">{label}</span>
          </div>
        ))}
      </div>
    )
  }

  <!-- Narrative sections -->
  <div class="case-study-content flex flex-col gap-y-6">
    <Content />
  </div>
</article>

<style>
  @reference "tailwindcss";

  .case-study-content :global(h2) {
    @apply text-2xl font-semibold text-gray-800 dark:text-gray-100 mt-8 mb-4;
  }
  .case-study-content :global(p) {
    @apply text-gray-700 dark:text-gray-400 text-pretty leading-relaxed mb-4;
  }
  .case-study-content :global(ul) {
    @apply list-disc list-inside mb-4 pl-4 text-gray-700 dark:text-gray-400;
  }
  .case-study-content :global(li) {
    @apply mb-2;
  }
  .case-study-content :global(code) {
    @apply bg-gray-100 dark:bg-gray-800 px-1.5 py-0.5 rounded text-sm text-red-600 dark:text-red-400 font-mono;
  }
  .case-study-content :global(strong) {
    @apply font-semibold text-gray-950 dark:text-white;
  }
</style>
