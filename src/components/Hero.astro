---
import { Image } from "astro:assets";
import meImage from "@/assets/me.jpeg";
import Badge from "@/components/Badge.astro";
import SocialPill from "@/components/SocialPill.astro";

import GitHubIcon from "@/icons/GitHubIcon.astro";
import EmailIcon from "@/icons/EmailIcon.astro";
import LinkedInIcon from "@/icons/LinkedInIcon.astro";
---

<div class="max-w-xl">
  <div class="flex gap-4 mb-4">
    <Image
      class="rounded-full size-16 object-cover"
      src={meImage}
      alt="Gino Lencina"
      loading="eager"
    />
    <a
      href="https://www.linkedin.com/in/ginolencina/"
      target="_blank"
      rel="noopener"
      class="flex justify-center items-center"
    >
      <Badge>Disponible para trabajar</Badge>
    </a>
  </div>

  <h1
    class="text-4xl font-bold tracking-tight text-gray-800 sm:text-5xl dark:text-white"
  >
    Gino Lencina | Full Stack Developer
  </h1>
  <p
    class="mt-6 text-xl text-gray-800 [&>strong]:text-accent [&>strong]:font-semibold dark:text-gray-300"
  >
    <strong>Especialista en Java, Spring Boot y React</strong> de San Miguel, Buenos Aires, Argentina.
    Enfocado en el desarrollo de aplicaciones web escalables, seguras y centradas en la experiencia del usuario (UX).
    Integro herramientas de IA —<strong>Claude, OpenCode</strong> y otras— al flujo completo de desarrollo, desde el diseño de arquitectura hasta la revisión de código.
  </p>
</div>

<nav class="flex gap-4 mt-8 flex-wrap">
  <SocialPill href="https://www.linkedin.com/in/ginolencina/">
    <LinkedInIcon class="size-4 md:size-6" />
    LinkedIn
  </SocialPill>
  <SocialPill href="https://github.com/GinoL221">
    <GitHubIcon class="size-4 md:size-6" />
    GitHub
  </SocialPill>
  <SocialPill href="mailto:ginolencina@gmail.com">
    <EmailIcon class="size-4 md:size-6" />
    ginolencina@gmail.com
  </SocialPill>
</nav>
